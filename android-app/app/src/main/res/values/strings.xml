    <!-- 无障碍服务 -->
    <string name="accessibility_service_label">AI文本助手 - 智能补全与问答</string>
    <string name="accessibility_service_description">
        此服务用于检测文本选择和复制操作，以提供AI智能补全和问答功能。
        
        功能说明：
        • 检测文本选择事件
        • 检测复制操作
        • 显示浮动操作按钮
        • 调用AI API进行文本处理
        
        需要此权限才能在其他应用中检测您的操作。
    </string>
    
